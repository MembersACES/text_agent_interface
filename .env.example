GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Vinyl wrap page: deterministic FastAPI spec board (default) vs legacy n8n mockup.
# VINYL_WRAP_GENERATOR_MODE=deterministic
# VINYL_WRAP_GENERATOR_MODE=n8n

# Optional: dedicated autonomous sequence API (defaults to main CRM API / NEXT_PUBLIC_API_BASE_URL)
# NEXT_PUBLIC_AUTONOMOUS_API_BASE_URL=https://autonomous-agent-backend-git-672026052958.australia-southeast2.run.app

# Optional (Cloud Run): server-only base for autonomous reads + runner triggers (wins over NEXT_PUBLIC_* on the server).
# MUST be the autonomous/runner Cloud Run URL if that service hosts your sequences — not the CRM monolith.
# AUTONOMOUS_API_URL=https://autonomous-agent-backend-git-672026052958.australia-southeast2.run.app

# Optional: force Start / Start-now proxy to a specific runner URL (overrides AUTONOMOUS_API_URL for those routes only).
# AUTONOMOUS_RUNNER_API_URL=https://autonomous-agent-backend-git-672026052958.australia-southeast2.run.app

# Comma-separated Google sign-in emails allowed to see Invoicing + /invoicing (server-only preferred on Cloud Run).
# INVOICING_ALLOWED_EMAILS="user@acesolutions.com.au"
# NEXT_PUBLIC_INVOICING_ALLOWED_EMAILS="user@acesolutions.com.au"

# Comma-separated emails allowed to see Personal Assistant in the nav + /personal-assistant.
# PERSONAL_ASSISTANT_ALLOWED_EMAILS="user@acesolutions.com.au"
# NEXT_PUBLIC_PERSONAL_ASSISTANT_ALLOWED_EMAILS="user@acesolutions.com.au"

# Full URL loaded inside the Personal Assistant iframe (origin + optional path, e.g. /clients).
# NEXT_PUBLIC_PERSONAL_ASSISTANT_CRM_URL=https://crm-frontend-dev-522472397014.australia-southeast2.run.app/

# Optional: bearer for POST /run/run/* and /run/step/* only — must match autonomous_agent_backend BACKEND_API_KEY.
# Use this when the interface's BACKEND_API_KEY must stay different from the runner's secret.
# AUTONOMOUS_RUNNER_API_KEY=same-as-autonomous-cloud-run-BACKEND_API_KEY
